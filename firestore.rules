rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Custom helper functions standard
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerifiedUser() && request.auth.token.email == 'taican4real@gmail.com';
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'score', 'timeUsed', 'answeredCount', 'updatedAt'])
        && data.keys().size() == 7
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 128
        && data.score is int && data.score >= 0 && data.score <= 1000
        && data.timeUsed is int && data.timeUsed >= 0 && data.timeUsed <= 5000
        && data.answeredCount is int && data.answeredCount >= 0 && data.answeredCount <= 35
        && data.updatedAt == request.time;
    }

    // Rules for participants collection
    match /participants/{participantId} {
      // Must target document using a valid ID format
      allow get: if isVerifiedUser() && (participantId == request.auth.uid || isAdmin());
      
      // Full listing query enforcer - only administrators can scrap and audit all participant records
      allow list: if isAdmin();

      // Creating a new participant score entry or updating an existing one
      allow create: if isVerifiedUser() 
        && participantId == request.auth.uid 
        && isValidId(participantId)
        && isValidParticipant(incoming());

      allow update: if isVerifiedUser() 
        && participantId == request.auth.uid 
        && isValidId(participantId)
        && isValidParticipant(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email;

      // Only administrators can prune/delete participant lists
      allow delete: if isAdmin();
    }
  }
}
